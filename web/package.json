{
  "name": "bilibili-vtuber-suite-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "test": "vitest",
    "test:e2e": "playwright test",
    "visual:check-png": "node scripts/check-visual-png.mjs",
    "api:export": "${BACKEND_PYTHON:-../backend/.venv/bin/python} ../scripts/export_openapi_schema.py --output openapi.json",
    "api:generate": "pnpm api:export && openapi-typescript openapi.json -o src/generated/api-schema.ts",
    "api:check": "pnpm api:generate && git diff --exit-code -- openapi.json src/generated/api-schema.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^0.468.0",
    "openapi-fetch": "^0.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "react-grab": "^0.1.48",
    "react-scan": "^0.5.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
